# App
APP_NAME=BoneBET
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# CS2 Analytics API
CS2_API_BASE_URL=http://localhost:8005
CS2_API_TIMEOUT=30
CS2_API_MAX_RETRIES=3

# Database
DATABASE_URL=sqlite+aiosqlite:///./bonebet.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# AI (LLM)
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4-turbo-preview
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# Metrics
METRIC_CALCULATION_INTERVAL_HOURS=6
SNAPSHOT_RETENTION_DAYS=90